{
  "deploy.reloaded": {
    "packages": [
      {
        "name": "Full Shop Deploy",
        "description": "部署 b2badmin, web 和 api",
        "files": [
          "apps/b2badmin/.next/**",
          "apps/web/.next/**",
          "apps/api/dist/**"
        ]
        // "deployOnSave": [
        //   "Production Server"
        // ]
      }
    ],
    "targets": [
      {
        "type": "sftp",
        "name": "Production Server",
        "host": "139.196.30.42",
        "user": "root",
        "password": "X23lw124323##",
        "dir": "/5/shop2/apps",
        "mappings": {
          "apps/b2badmin/.next/": "b2badmin/.next/",
          "apps/web/.next/": "web/.next/",
          "apps/api/dist/": "api/dist/"
        }
      }
    ]
  },
  "editor.codeActionsOnSave": {
    "source.fixAll.biome": "explicit",
    "source.organizeImports.biome": "explicit"
  },
  // TypeScript (Native Preview) > Use Tsgo
  "typescript.experimental.useTsgo": true,
  "files.watcherExclude": {
    "**/.next/**": true,
    "**/node_modules/**": true,
    "**/.cache/**": true
  },
  // 排除大型目录（防止 TS 扫描）
  "files.exclude": {
    "**/node_modules": true,
    "**/build": true,
    "apps/*/node_modules": true,
    "packages/*/node_modules": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true
  },
  "material-icon-theme.folders.associations": {
    "_lib": "library", // 📚
    "_generated": "temp", // ⚙️
    "_custom": "constant" // 🛠️
  },
  "cSpell.words": [
    "elysia",
    "elysiajs",
    "lucide",
    "pinia",
    "primevue",
    "Skus",
    "usetoast"
  ],
  "[javascript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "[typescript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "[json]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[css]": {
    "editor.defaultFormatter": "vscode.css-language-features"
  },
  "[graphql]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  "emmet.showExpandedAbbreviation": "never",
  "[html]": {
    "editor.defaultFormatter": "vscode.html-language-features"
  },
  "trae.tab.enableRename": false,
  "trae.tab.enableAutoImport": false,
  "typescript.tsdk": "node_modules\\typescript\\lib",
  "claudeCodeChat.permissions.yoloMode": true
}
